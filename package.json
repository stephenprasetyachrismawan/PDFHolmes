{
  "name": "pdfholmes",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "node db/migrate.mjs",
    "compose:dev": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.dev.yml up -d",
    "compose:down": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.dev.yml down"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
