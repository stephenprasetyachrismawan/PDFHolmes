# ─────────────────────────────────────────────────────────────
# PDFHo!mes — contoh environment. Salin ke .env lalu isi nilainya.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ---- Database (DEV: container db; PROD: endpoint Aurora) ----
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev_password
POSTGRES_DB=pdfholmes
# api/extractor/analyzer pakai ini. DEV -> host "db". PROD -> endpoint Aurora.
DATABASE_URL=postgres://app:app_dev_password@db:5432/pdfholmes

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- MinIO (S3-compatible) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_ENDPOINT=http://minio:9000
# Endpoint yang dilihat browser (presigned URL). DEV via proxy/localhost.
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1

# ---- GROBID ----
GROBID_URL=http://grobid:8070

# ---- Cognito (Auth) ----
COGNITO_REGION=ap-southeast-1
COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_xxxxxxxxx
COGNITO_JWKS_URL=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_xxxxxxxxx/.well-known/jwks.json

# ---- web (Next.js / Auth.js) ----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- api (NestJS) ----
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# ---- Enkripsi kredensial AI (§16) ----
# Fernet key (32 byte url-safe base64). DEV pakai ini; PROD pakai KMS envelope.
CREDENTIAL_ENC_KEY=ZmFrZS1kZXYta2V5LXJlcGxhY2UtMzItYnl0ZXMtbG9uZ19fXw==
# Opsional prod: ARN KMS untuk envelope encryption
KMS_KEY_ID=

# ---- analyzer ----
# Default embedding dim harus cocok dgn kolom vector(1536) di DB.
EMBEDDING_DIM=1536
DEFAULT_LANGUAGE=id
CODEX_ENABLED=false

# ─────────────────────────────────────────────────────────────
# OpenCode Go — penyedia AI TUNGGAL (NON-BYOK).
# Key HANYA di server (api + analyzer). JANGAN pernah pakai prefix
# NEXT_PUBLIC_ untuk key ini; itu akan membocorkannya ke browser.
# ─────────────────────────────────────────────────────────────
OPENCODE_GO_API_KEY=replace_with_your_opencode_go_key
OPENCODE_GO_MODEL=minimax-m2.7
# anthropic -> /v1/messages ; openai -> /v1/chat/completions
OPENCODE_GO_PROVIDER_TYPE=anthropic
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go
# Batas keamanan / kuota (opsional; nilai default ditampilkan).
OPENCODE_GO_MAX_TOKENS=2000
OPENCODE_GO_MAX_INPUT_CHARS=8000
OPENCODE_GO_TIMEOUT_MS=60000
OPENCODE_GO_USER_RATE_PER_MIN=20
OPENCODE_GO_GLOBAL_RATE_PER_MIN=300
