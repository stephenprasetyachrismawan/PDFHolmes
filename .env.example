# ─────────────────────────────────────────────────────────────
# PDFHo!mes — contoh environment. Salin ke .env lalu isi nilainya.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ---- Database: Aurora PostgreSQL + IAM auth (lihat docs/DATABASE.md) ----
# Tanpa password: user 'app' (rds_iam) pakai token IAM 15-menit + SSL.
# Kredensial AWS dari instance role EC2 (rds-db:connect).
DATABASE_URL=postgres://app@<cluster-endpoint>:5432/pdfholmes
DB_IAM_AUTH=true
DB_IAM_REGION=ap-southeast-1

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- MinIO (S3-compatible) ----
MINIO_ROOT_USER=ganti-user
MINIO_ROOT_PASSWORD=ganti-dengan-password-kuat
MINIO_ENDPOINT=http://minio:9000
# Endpoint presigned yang dibuka browser (subdomain dgn DNS sendiri, atau sslip.io).
MINIO_PUBLIC_ENDPOINT=https://minio.pdfholmes.contoh.com
MINIO_REGION=us-east-1
# URL publik console MinIO (port 9001) — dipakai MINIO_BROWSER_REDIRECT_URL.
MINIO_CONSOLE_URL=https://console.minio.pdfholmes.contoh.com

# ---- Domain (dipakai Caddy untuk vhost + TLS) ----
WEB_DOMAIN=pdfholmes.contoh.com
MINIO_DOMAIN=minio.pdfholmes.contoh.com
# Console UI MinIO (port 9001), domain terpisah dari API S3.
MINIO_CONSOLE_DOMAIN=console.minio.pdfholmes.contoh.com
# Portainer (UI Docker) dilindungi basic_auth di Caddyfile.
PORTAINER_DOMAIN=portainer.pdfholmes.contoh.com
# pgweb (browse Aurora) dilindungi basic_auth; container on-demand (scripts/db-gui.sh).
PGWEB_DOMAIN=db.pdfholmes.contoh.com

# ---- Cognito (login; lihat docs/COGNITO.md) ----
COGNITO_REGION=ap-southeast-1
COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_xxxxxxxxx
COGNITO_JWKS_URL=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_xxxxxxxxx/.well-known/jwks.json
AUTH_DEV_BYPASS=false

# ---- web (Next.js / Auth.js) ----
NEXTAUTH_URL=https://pdfholmes.contoh.com
NEXTAUTH_SECRET=ganti-generate-dgn-openssl-rand-base64-32
NEXT_PUBLIC_API_URL=https://pdfholmes.contoh.com

# ---- api (NestJS) ----
API_PORT=4000
WEB_ORIGIN=https://pdfholmes.contoh.com

# ---- analyzer ----
# Embedding dim harus cocok dgn kolom vector(1536) di DB.
EMBEDDING_DIM=1536
DEFAULT_LANGUAGE=id

# ─────────────────────────────────────────────────────────────
# OpenCode Go — penyedia AI TUNGGAL (NON-BYOK). Lihat docs/OPENCODE.md.
# Key HANYA di server (api + analyzer). JANGAN pakai prefix NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────
OPENCODE_GO_API_KEY=sk-ganti-dengan-key-anda
OPENCODE_GO_MODEL=minimax-m2.7
# anthropic -> /v1/messages (header x-api-key) ; openai -> /v1/chat/completions
OPENCODE_GO_PROVIDER_TYPE=anthropic
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go
# Batas keamanan / kuota (nilai default ditampilkan).
OPENCODE_GO_MAX_TOKENS=2000
OPENCODE_GO_MAX_INPUT_CHARS=8000
OPENCODE_GO_TIMEOUT_MS=60000
OPENCODE_GO_USER_RATE_PER_MIN=20
OPENCODE_GO_GLOBAL_RATE_PER_MIN=300
