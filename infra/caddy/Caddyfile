# Caddy reverse proxy + auto-HTTPS publik (Let's Encrypt).
# Hanya port 80/443 yang perlu dibuka di AWS Security Group; port 80 harus
# reachable dari internet untuk tantangan HTTP-01.
#
# Domain di-inject dari env:
#   WEB_DOMAIN       = host web+API (satu origin), mis. pdfholmes.stevewithcode.net
#   MINIO_DOMAIN     = host MinIO S3 untuk presigned upload/download
#   PORTAINER_DOMAIN = host UI Portainer (dilindungi basic_auth)

{
	# email opsional utk notifikasi Let's Encrypt:
	# email you@example.com
}

# ---- Web + API (satu origin) ----
{$WEB_DOMAIN} {
	encode gzip zstd

	# Auth.js (NextAuth) hidup di service web, BUKAN api NestJS.
	# Harus didahulukan dari /api/* (matcher lebih spesifik) agar callback
	# OAuth Cognito (/api/auth/callback/cognito) sampai ke web.
	handle /api/auth/* {
		reverse_proxy web:3000
	}

	# Sisa /api/* -> NestJS (prefix /api dipertahankan). SSE: flush_interval -1.
	handle /api/* {
		reverse_proxy api:4000 {
			flush_interval -1
		}
	}

	handle {
		reverse_proxy web:3000
	}
}

# ---- MinIO S3 API (presigned URL upload/download) ----
# Ini API S3, BUKAN halaman UI — buka di browser akan menampilkan XML AccessDenied.
# Dipakai app sbg MINIO_PUBLIC_ENDPOINT; HARUS tetap ke port 9000.
{$MINIO_DOMAIN} {
	reverse_proxy minio:9000
}

# ---- MinIO Console (UI manajemen, port 9001) ----
# Domain terpisah dari API. Login pakai MINIO_ROOT_USER / MINIO_ROOT_PASSWORD.
# MINIO_BROWSER_REDIRECT_URL (env minio) harus = https://{$MINIO_CONSOLE_DOMAIN}.
{$MINIO_CONSOLE_DOMAIN} {
	reverse_proxy minio:9001
}

# ---- Portainer (UI manajemen Docker) — dilindungi basic_auth ----
# Portainer serve HTTPS self-signed di 9443; lewati verifikasi TLS internal.
{$PORTAINER_DOMAIN} {
	basic_auth {
		admin $2a$14$WCYE8dIuw3vNEdIsR5m8M.fEpaYgZlLqcAP8vvD/5YnzvrczMXiK.
	}
	reverse_proxy https://portainer:9443 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}
