# Caddy reverse proxy + auto-HTTPS publik (Let's Encrypt).
# Hanya port 80/443 yang perlu dibuka di AWS Security Group; port 80 harus
# reachable dari internet untuk tantangan HTTP-01.
#
# Domain di-inject dari env:
#   WEB_DOMAIN   = host web+API (satu origin), mis. pdfholmes.stevewithcode.net
#   MINIO_DOMAIN = host MinIO S3 untuk presigned upload/download

{
	# email opsional utk notifikasi Let's Encrypt:
	# email you@example.com
}

# ---- Web + API (satu origin) ----
{$WEB_DOMAIN} {
	encode gzip zstd

	# Auth.js (NextAuth) hidup di service web, BUKAN api NestJS.
	# Harus didahulukan dari /api/* (matcher lebih spesifik) agar callback
	# OAuth Cognito (/api/auth/callback/cognito) sampai ke web.
	handle /api/auth/* {
		reverse_proxy web:3000
	}

	# Sisa /api/* -> NestJS (prefix /api dipertahankan). SSE: flush_interval -1.
	handle /api/* {
		reverse_proxy api:4000 {
			flush_interval -1
		}
	}

	handle {
		reverse_proxy web:3000
	}
}

# ---- MinIO S3 API (presigned URL upload/download) ----
{$MINIO_DOMAIN} {
	reverse_proxy minio:9000
}
