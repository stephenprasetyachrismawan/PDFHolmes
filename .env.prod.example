# ───────────────────────────────────────────────────────────────────
# PDFHo!mes — .env PRODUKSI. Salin ke .env.prod & isi dari output Terraform
# (infra/aws) + Secrets Manager. JANGAN commit file terisi.
#   cp .env.prod.example .env.prod
# ───────────────────────────────────────────────────────────────────

NODE_ENV=production

# ---- Database: Aurora (dari Secrets Manager / output terraform aurora_endpoint) ----
# Ambil URL lengkap: aws secretsmanager get-secret-value --secret-id pdfholmes/aurora/credentials
DATABASE_URL=postgres://pdfholmes_admin:CHANGE_ME@pdfholmes-aurora.cluster-xxxx.ap-southeast-1.rds.amazonaws.com:5432/pdfholmes

# ---- Redis (internal compose) ----
REDIS_URL=redis://redis:6379

# ---- MinIO: GANTI kredensial default (§16) ----
MINIO_ROOT_USER=pdfholmes_minio
MINIO_ROOT_PASSWORD=GENERATE_STRONG_64CHAR
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=https://minio.pdfholmes.example.com
MINIO_CONSOLE_URL=https://console.pdfholmes.example.com
MINIO_REGION=ap-southeast-1

# ---- GROBID ----
GROBID_URL=http://grobid:8070
GROBID_ENABLED=true

# ---- Cognito (output terraform) ----
COGNITO_REGION=ap-southeast-1
COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_ISSUER=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_xxxxxxxxx
COGNITO_JWKS_URL=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_xxxxxxxxx/.well-known/jwks.json

# ---- web (Auth.js) ----
NEXTAUTH_URL=https://pdfholmes.example.com
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32
NEXT_PUBLIC_API_URL=https://pdfholmes.example.com/api

# ---- api ----
API_PORT=4000
WEB_ORIGIN=https://pdfholmes.example.com

# ---- KEAMANAN: WAJIB false di produksi ----
AUTH_DEV_BYPASS=false

# ---- Enkripsi kredensial AI (§16) — 32 byte base64; rahasia ----
CREDENTIAL_ENC_KEY=GENERATE_WITH_openssl_rand_base64_32

# ---- analyzer ----
EMBEDDING_DIM=1536
DEFAULT_LANGUAGE=id
ANALYZER_MOCK=false

# ---- Codex (opsional, §8.3 — utamakan BYOK API key) ----
CODEX_ENABLED=false
CODEX_DEVICE_MOCK=false
INSTALL_CODEX=false
CODEX_DEFAULT_MODEL=gpt-5.1-codex
CODEX_AUTH_URL=http://codex-auth:8090

# ---- Caddy: domain publik utk auto-HTTPS ----
BASE_DOMAIN=pdfholmes.example.com
# Email utk Let's Encrypt (notifikasi kedaluwarsa & pemulihan akun)
ACME_EMAIL=admin@example.com
